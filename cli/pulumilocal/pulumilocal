#!/usr/bin/env bash
#
# pulumilocal — Pulumi CLI wrapper that auto-configures Pulumi to use robotocore endpoints.
#
# Usage:
#   pulumilocal [pulumi args...]
#
# Environment variables:
#   ROBOTOCORE_HOST             Custom hostname (default: localhost)
#   ROBOTOCORE_PORT             Custom port (default: 4566)
#   ROBOTOCORE_ENDPOINT         Full endpoint URL (overrides host/port)
#   PULUMI_BACKEND_URL          Pulumi state backend (default: file://~)
#   PULUMI_CONFIG_PASSPHRASE    Encryption passphrase (default: test)
#
set -euo pipefail

# Check pulumi is installed
if ! command -v pulumi &>/dev/null; then
    echo "Error: 'pulumi' not found on PATH." >&2
    echo "Install Pulumi: https://www.pulumi.com/docs/install/" >&2
    exit 1
fi

# Determine endpoint
if [[ -n "${ROBOTOCORE_ENDPOINT:-}" ]]; then
    ENDPOINT="$ROBOTOCORE_ENDPOINT"
else
    HOST="${ROBOTOCORE_HOST:-localhost}"
    PORT="${ROBOTOCORE_PORT:-4566}"
    ENDPOINT="http://${HOST}:${PORT}"
fi

# Set AWS endpoint
export AWS_ENDPOINT_URL="$ENDPOINT"

# Set credentials (don't override user-set values)
export AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID:-test}"
export AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY:-test}"
export AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-us-east-1}"

# Set Pulumi defaults (don't override user-set values)
export PULUMI_CONFIG_PASSPHRASE="${PULUMI_CONFIG_PASSPHRASE:-test}"
export PULUMI_BACKEND_URL="${PULUMI_BACKEND_URL:-file://~}"

# Pass all arguments through to pulumi
exec pulumi "$@"
